NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://nstcloud:password@localhost:5432/nst_cloud?sslmode=disable
REDIS_URL=redis://localhost:6379
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret
SESSION_SECRET=super_secret_session_key
ENCRYPTION_KEY=super_secret_encryption_key_32_chars!
DOCKER_SOCKET_PATH=/var/run/docker.sock
TRAEFIK_DOMAIN=nstcloud.local
WILDCARD_BASE_DOMAIN=apps.nstcloud.local
NEXT_PUBLIC_API_URL=http://localhost:4000
